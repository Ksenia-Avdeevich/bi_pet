				let
				    Источник = Csv.Document(File.Contents("D:\личное\т-банк экз\2026\пэт\bi\finance_transactions.csv"),[Delimiter=";", Columns=15, Encoding=1251, QuoteStyle=QuoteStyle.None]),
				    #"Повышенные заголовки" = Table.PromoteHeaders(Источник, [PromoteAllScalars=true]),
				    #"Измененный тип с языком" = Table.TransformColumnTypes(#"Повышенные заголовки", {{"amount", type number}}, "en-US"),
