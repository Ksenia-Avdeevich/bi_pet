				    #"Измененный тип с языком2" = Table.TransformColumnTypes(#"Измененный тип", {{"tax_amount", type number}}, "en-US"),
				    #"Измененный тип1" = Table.TransformColumnTypes(#"Измененный тип с языком2",{{"risk_score", Int64.Type}}),
				    #"Удаленные дубликаты" = Table.Distinct(#"Измененный тип1", {"transaction_id"}),
				    #"Обрезанный текст" = Table.TransformColumns(#"Удаленные дубликаты",{{"channel", Text.Trim, type text}}),
				    #"Вычисленное абсолютное значение" = Table.TransformColumns(#"Обрезанный текст",{{"amount", Number.Abs, type number}}),
				    #"Замененное значение" = Table.ReplaceValue(#"Вычисленное абсолютное значение",null,14.52,Replacer.ReplaceValue,{"fee_amount"}),
				    #"Текст в верхнем регистре" = Table.TransformColumns(#"Замененное значение",{{"currency", Text.Upper, type text}})
				in
