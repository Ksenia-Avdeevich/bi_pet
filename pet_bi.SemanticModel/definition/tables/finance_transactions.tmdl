table finance_transactions
	lineageTag: 3000f5ce-2316-4cf9-87ab-c1efa85c6e9d

	measure 'dahboard title' = "Финансовый анализ"
		lineageTag: 6efacf11-56bd-4d94-9ba1-826ea8321ea5

	measure 'total amount' = ```
			SUM(finance_transactions[amount]) 
			```
		lineageTag: 97bf96aa-006f-4f89-9889-60d8120aee76

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'PY amount' = CALCULATE([total amount], SAMEPERIODLASTYEAR('calendar'[Date]))
		lineageTag: 391f4780-072d-45cf-9634-50e453a3d7b8

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'YoY amount' = [total amount] - [PY amount]
		lineageTag: 8d08fc28-9dc6-4cdc-8235-77432d7404d0

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'YoY % amount' = ```
			DIVIDE([YoY amount], [PY amount]) 
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 44115135-1104-4298-b64c-1024e8f1bf24

	measure 'total transactions' = ```
			DISTINCTCOUNT(finance_transactions[transaction_id]) 
			```
		formatString: 0
		lineageTag: c43f9d61-54e6-4861-b285-eb4d582f685e

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'PY transaction' = CALCULATE([total transactions], SAMEPERIODLASTYEAR('calendar'[Date]))
		formatString: 0
		lineageTag: b3d74f90-3abf-4bcc-89a1-e33827a0c62c

	measure 'YoY transactions' = ```
			[total transactions] - [PY transaction] 
			```
		lineageTag: aa9c4228-b6cf-44d1-8a9d-1e4486dca603

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'YoY % transactions' = ```
			DIVIDE([YoY transactions], [PY transaction]) 
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 5d9f3ca1-d799-4313-a005-c11eeabcedee

	measure 'avg transaction value' = ```
			AVERAGE(finance_transactions[amount]) 
			```
		lineageTag: a1087969-4cf3-4ee4-b059-5a30c1a0b2ea

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'PY avg transaction' = CALCULATE([avg transaction value], SAMEPERIODLASTYEAR('calendar'[Date]))
		lineageTag: af9a8640-46dc-457b-92ea-d31efa534e1a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'YoY avg transactions' = ```
			[avg transaction value] - [PY avg transaction] 
			```
		lineageTag: af79af45-bd10-423a-bb6d-b7bbcfbca6e7

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'YoY % avg transactions' = ```
			DIVIDE([YoY avg transactions], [PY avg transaction]) 
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 3e040c9f-4222-45d8-821b-18381f2490fd

	measure 'total fees' = ```
			SUM(finance_transactions[fee_amount]) 
			```
		lineageTag: 2d31af11-3997-462b-8a81-f3f0de2d5b37

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'PY fees' = CALCULATE([total fees], SAMEPERIODLASTYEAR('calendar'[Date]))
		lineageTag: 2a4e50f7-6da2-444e-8e98-7eac557d8e51

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'YoY fees' = ```
			[total fees] - [PY fees] 
			```
		lineageTag: 6a3df9a2-f18d-44d1-9180-35746407b6b6

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'YoY % fees' = ```
			DIVIDE([YoY fees], [PY fees]) 
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: b6e6c622-3bc0-448f-acf9-ea0588d462b2

	measure 'selected year' = SELECTEDVALUE('calendar'[year])
		formatString: 0
		lineageTag: ab7f9758-2794-45cf-a2af-5c953536bb29

	measure 'selected dynamic measure' = SELECTEDVALUE('dynamic metric'[dynamic title])
